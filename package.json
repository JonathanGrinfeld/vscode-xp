{
  "name": "vscode-xp",
  "publisher": "JonathanGrinfeld",
  "displayName": "vscode-xp",
  "icon": "assets/vscode-xp.png",
  "description": "Earn XP whenever you save a file and climb to the highest level!",
  "version": "1.0.2",
  "engines": {
    "vscode": "^1.70.0"
  },
  "repository": {"url": "https://github.com/JonathanGrinfeld/vscode-xp.git"},
  "files": ["out", "assets", "README.md", "CHANGELOG.md"],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vscx.showStats",
    "onCommand:vscx.configureXp",
    "onCommand:vscx.toggleInfoMessages",
    "onCommand:vscx.toggleStatusBarConfetti",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "vscode-xp",
      "properties": {
        "vscode-xp.xpMultiplier": {
          "type": "number",
          "default": 1,
          "minimum": 0.1,
          "maximum": 100,
          "description": "Multiplier applied to XP earned on save."
        },
        "vscode-xp.showInfoMessages": {
          "type": "boolean",
          "default": true,
          "description": "Show information messages for level-ups and XP actions."
        },
        "vscode-xp.showStatusBarConfetti": {
          "type": "boolean",
          "default": true,
          "description": "Show confetti animation in the status bar when leveling up."
        }
      }
    },
    "commands": [
      {
        "command": "vscx.showStats",
        "title": "vscode-xp: Show XP Stats"
      },
      {
        "command": "vscx.configureXp",
        "title": "vscode-xp: Configure XP Settings"
      },
      {
        "command": "vscx.toggleInfoMessages",
        "title": "vscode-xp: Toggle Info Messages"
      },
      {
        "command": "vscx.toggleStatusBarConfetti",
        "title": "vscode-xp: Toggle Status Bar Confetti"
      },
      {
        "command": "vscx.reset",
        "title": "vscode-xp: Reset XP bar"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc --noEmit -p ./",
    "bundle": "tsdown",
    "watch": "tsdown --watch",
    "pretest": "npm run bundle",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package --out versions/"
  },
  "devDependencies": {
    "@types/node": "^16.x",
    "@types/vscode": "^1.70.0",
    "tsdown": "^0.10.2",
    "tslint": "^6.1.3",
    "typescript": "^4.7.0",
    "vsce": "^1.97.0"
  }
}
